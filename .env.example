# ===============================
# ENABLE CLI MODE
# ===============================
ENABLE_CLI_MODE=false

# ===============================
# WEBSITE CONFIGURATION
# ===============================
 
# Base URL of the target website (required)
WEBSITE_URL=https://dev-pr.infochecker.com


# ===============================
# CLOUDFLARE ACCESS (Optional)
# ===============================
# Required if the site is protected by Cloudflare Access Service Tokens
CF_ACCESS_CLIENT_ID= "your clint id"
CF_ACCESS_CLIENT_SECRET=" your token"
 
# ===============================
# PUPPETEER SETTINGS
# ===============================
 
# Run browser without visible UI (true/false)
PUPPETEER_HEADLESS=false
 
# Launch browser in maximized window (true/false)
PUPPETEER_START_MAXIMIZED=true
 
# Browser viewport: "null" for full window, or JSON like {"width":1280,"height":800}
PUPPETEER_DEFAULT_VIEWPORT=null
 
# ===============================
# Select Subscription Flow
# ===============================
 
# Choose one flow to enable. Set the desired flow to true, all others to false.
ENABLE_DISCOUNTED_FULL_FLOW=true
ENABLE_PRO_ACCESS_FLOW=false
ENABLE_STANDARD_FLOW=false
ENABLE_PAID_PLATFORM_ACCESS=false
 
# ===============================
# Funnel Subscription Flow
# ===============================

ENABLE_FREE_PLATFORM_ACCESS=false
ENABLE_PAID_PLATFORM=false

# ===============================
# USER SETTINGS
# ===============================
 
# Number of users to register in one run
USER_REGISTRATION_COUNT=1
 
# ===============================
# CARD DETAILS (required for payment)
# ===============================
 
# 16-digit card number
CARD_NUMBER=4067429974719265

PAID_VISA_CARD_NUMBER=4532456618142692
 
# Expiry in MM/YY format
CARD_EXPIRY=12/34
 
# 3 or 4 digit CVV
CARD_CVV=123
 
# ===============================
# REPORT SETTINGS
# ===============================
 
# Generate reports after registration (true/false)
ENABLE_CREATE_REPORT=false
 
# Number of reports to generate (integer)
REPORT_COUNT=1
 
# Unlock the latest report after generation (true/false)
UNLOCK_REPORT=false
 
# ===============================
# PDF SUBSCRIPTION
# ===============================
 
# Download PDF after registration (true/false)
DOWNLOAD_PDF=false
 
# ===============================
# HTML REPORT FOR USER DETAILS
# ===============================
 
# Generate HTML page with registered user credentials (true/false)
HTML_PAGE_CREATION_FOR_USER_DETAILS=false
 
# Auto-open generated HTML pages in browser (true/false)
OPEN_HTML_PAGES=false
 
# ===============================
# TIMEOUTS (milliseconds)
# ===============================
 
# Page load / element wait timeout
PAGE_TIMEOUT=90000
 
# Iframe load timeout
IFRAME_TIMEOUT=120000
 
# Report generation timeout
REPORT_TIMEOUT=60000
 
# ===============================
# DELAYS (milliseconds)
# ===============================
 
# Delay after clicks to allow page to respond
COMMON_DELAY_ONCLICKS=200
 
# Delay between keystrokes when typing
TYPING_DELAY=50
 
# Delay before click actions in PDF flow
CLICK_DELAY_MS=200
 
# ===============================
# RETRY SETTINGS
# ===============================
 
# Maximum retry attempts per user
MAX_RETRIES=3
 
# Delay between retries (milliseconds)
RETRY_DELAY_MS=5000
 
# ===============================
# BROWSER BEHAVIOR
# ===============================
 
# Close browser when automation completes (true/false)
BROWSER_CLOSE_ON_COMPLETION=false

# ===============================
# RECORDING SETTINGS
# ===============================

# Enable screen recording for proof (true/false)
ENABLE_RECORDING=false

# Custom path to save recordings (e.g., D:\recordings). Leave empty for default ./recordings
RECORDING_SAVE_PATH=
 